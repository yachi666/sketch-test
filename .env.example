# ─── SketchTest Environment Variables ───────────────────────────────
# Copy this file to .env and adjust values for your local setup.

# ─── Hermetic Fixture Server ───────────────────────────────────────
# Fault injection mode: timeout | 500 | slow
# FAULT_MODE=

# Fault injection target path (e.g., /api/payments)
# FAULT_TARGET=

# ─── Control Plane (when implemented) ──────────────────────────────
# CONTROL_PLANE_URL=http://localhost:3800
# DATABASE_URL=postgresql://localhost:5432/sketchtest

# ─── Runner ───────────────────────────────────────────────────────
# RUNNER_ID=runner-local
# RUNNER_VERSION=0.1.0

# ─── Object Storage (S3-compatible) ───────────────────────────────
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=sketchtest-artifacts

# ─── AI Worker (when implemented) ──────────────────────────────────
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-6
